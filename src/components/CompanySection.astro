---
import { AnimatedCounter } from "./AnimatedCounter.tsx";
---

<section class="section-over-hero bg-surface py-28 md:py-44 px-6 md:px-16 lg:px-24" data-theme="dark">
  <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
        About Us
      </p>
    </div>

    <div class="lg:w-2/3">
      <p
        data-reveal
        style="--delay: 100ms"
        class="text-2xl md:text-4xl lg:text-[2.75rem] font-bold leading-[1.15] tracking-tight mb-20"
      >
        We are a growth partner for local businesses. We design, build, and
        optimize websites that turn visitors into paying customers —
        <span class="text-accent">always taking the initiative.</span>
      </p>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-12 mb-12">
        <div data-reveal style="--delay: 200ms" class="border-t border-rule-light pt-6">
          <span class="text-4xl md:text-5xl font-bold tracking-tight block mb-2">
            <AnimatedCounter client:visible target={147} suffix="+" />
          </span>
          <span class="text-xs text-ink-muted">Sites Launched</span>
        </div>
        <div data-reveal style="--delay: 300ms" class="border-t border-rule-light pt-6">
          <span class="text-4xl md:text-5xl font-bold tracking-tight block mb-2">
            <AnimatedCounter client:visible target={98} suffix="%" />
          </span>
          <span class="text-xs text-ink-muted">Client Retention</span>
        </div>
        <div data-reveal style="--delay: 400ms" class="border-t border-rule-light pt-6">
          <span class="text-4xl md:text-5xl font-bold tracking-tight block mb-2">
            <AnimatedCounter client:visible target={40} suffix="%" />
          </span>
          <span class="text-xs text-ink-muted">Avg. Conversion Lift</span>
        </div>
      </div>

      <a
        href="/work"
        data-reveal
        style="--delay: 500ms"
        class="inline-flex items-center gap-3 px-6 py-3 rounded-full border border-accent text-accent text-sm font-medium hover:bg-accent hover:text-surface transition-all duration-300"
      >
        See Our Work
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path
            d="M2 7h10M8 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    </div>
  </div>
</section>

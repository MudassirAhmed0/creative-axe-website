---
interface Props {
  headline?: string;
  description?: string;
}

const {
  headline = "Ready to grow?",
  description = "Let's build a website that actually works for your business.",
} = Astro.props;
---

<section
  id="contact"
  class="section-over-hero relative py-28 md:py-44 px-6 md:px-16 lg:px-24 text-center overflow-hidden"
  data-theme="light"
>
  <!-- Orange gradient bg -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent via-[#ea580c] to-[#c2410c]"></div>

  <!-- Subtle grain -->
  <div class="absolute inset-0 grain"></div>

  <div class="relative z-10">
    <p
      data-reveal
      class="text-sm text-black/50 font-mono tracking-widest uppercase mb-8"
    >
      Get Started
    </p>
    <h2
      data-reveal
      style="--delay: 100ms"
      class="text-[clamp(2.5rem,7vw,6rem)] font-bold text-black leading-[0.92] tracking-tight mb-6"
    >
      {headline}
    </h2>
    <p
      data-reveal
      style="--delay: 200ms"
      class="text-black/60 text-base md:text-lg max-w-md mx-auto mb-12 leading-relaxed"
    >
      {description}
    </p>
    <a
      data-reveal
      style="--delay: 300ms"
      href="mailto:hello@creativeaxe.co"
      class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-black text-white text-sm font-semibold hover:bg-surface transition-colors duration-300"
    >
      Start Your Project
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path
          d="M2 7h10M8 3l4 4-4 4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>
</section>

---
const year = new Date().getFullYear();
---

<footer class="bg-surface border-t border-rule px-6 md:px-16 lg:px-24 py-16 md:py-24" data-theme="dark">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
    <div data-reveal>
      <a href="/" class="flex items-center gap-2 group">
        <span class="w-2 h-2 rounded-full bg-accent group-hover:scale-125 transition-transform duration-300"></span>
        <span class="text-base font-semibold tracking-tight">Creative Axe</span>
      </a>
      <p class="text-sm text-ink-muted mt-3 leading-relaxed">
        Design. Build. Grow.
      </p>
    </div>

    <div data-reveal style="--delay: 100ms">
      <p class="text-[11px] text-ink-muted uppercase tracking-[0.15em] font-mono mb-4">
        Services
      </p>
      <nav class="flex flex-col gap-3">
        <a href="/services" class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300">Web Design</a>
        <a href="/services" class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300">Local SEO</a>
        <a href="/services" class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300">Content Strategy</a>
        <a href="/services" class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300">Marketing</a>
      </nav>
    </div>

    <div data-reveal style="--delay: 200ms">
      <p class="text-[11px] text-ink-muted uppercase tracking-[0.15em] font-mono mb-4">
        Industries
      </p>
      <nav class="flex flex-col gap-3">
        {
          [
            { label: "Restaurants", slug: "restaurants" },
            { label: "Dentists", slug: "dentists" },
            { label: "Contractors", slug: "contractors" },
            { label: "Lawyers", slug: "lawyers" },
            { label: "HVAC", slug: "hvac" },
            { label: "Plumbers", slug: "plumbers" },
          ].map((item) => (
            <a
              href={`/for/${item.slug}`}
              class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div data-reveal style="--delay: 300ms">
      <p class="text-[11px] text-ink-muted uppercase tracking-[0.15em] font-mono mb-4">
        Contact
      </p>
      <nav class="flex flex-col gap-3">
        <a
          href="mailto:hello@creativeaxe.co"
          class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300"
        >hello@creativeaxe.co</a>
      </nav>
    </div>
  </div>

  <div class="border-t border-rule" data-reveal-line style="--delay: 400ms"></div>
  <div
    class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
  >
    <p class="text-xs text-ink-muted">
      &copy; {year} Creative Axe. All rights reserved.
    </p>
  </div>
</footer>

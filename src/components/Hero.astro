---
---

<section
  class="hero-sticky relative min-h-[100svh] bg-surface flex flex-col overflow-hidden"
  data-theme="dark"
>
  <!-- Background accent glow — follows mouse -->
  <div
    data-mouse-parallax="-0.5"
    class="absolute top-1/4 right-[-10%] w-[700px] h-[700px] rounded-full opacity-[0.05] blur-[150px] pointer-events-none"
    style="background: radial-gradient(circle, #f97316 0%, transparent 70%); will-change: transform;"
  >
  </div>

  <!-- Secondary glow — opposite direction -->
  <div
    data-mouse-parallax="0.3"
    class="absolute bottom-1/4 left-[-10%] w-[500px] h-[500px] rounded-full opacity-[0.03] blur-[120px] pointer-events-none"
    style="background: radial-gradient(circle, #f97316 0%, transparent 70%); will-change: transform;"
  >
  </div>

  <!-- Grain -->
  <div class="absolute inset-0 grain pointer-events-none"></div>

  <!-- Main content -->
  <div class="relative z-10 flex-1 flex flex-col justify-between px-6 md:px-16 lg:px-24 pt-28 md:pt-36 pb-12 md:pb-16">
    <!-- Headline -->
    <div class="flex-1 flex flex-col justify-center">
      <div class="mb-6">
        <p
          data-hero-reveal
          style="--delay: 200ms"
          class="text-sm md:text-base text-accent font-mono tracking-wide mb-6 md:mb-8"
        >
          Web Design Agency
        </p>
      </div>

      <h1 class="text-[clamp(3rem,10vw,9rem)] font-bold leading-[0.88] tracking-[-0.04em]">
        <div data-line-reveal style="--delay: 400ms">
          <span>We build websites</span>
        </div>
        <div data-line-reveal style="--delay: 550ms">
          <span>that <em class="text-accent not-italic">convert</em></span>
        </div>
      </h1>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-8 md:gap-12">
      <!-- Stats ticker -->
      <div
        data-hero-reveal
        style="--delay: 800ms"
        class="flex gap-10 md:gap-16"
      >
        <div>
          <span class="text-2xl md:text-3xl font-bold tracking-tight">147+</span>
          <span class="block text-xs text-ink-muted mt-1">Sites Launched</span>
        </div>
        <div class="w-px bg-rule-light self-stretch"></div>
        <div>
          <span class="text-2xl md:text-3xl font-bold tracking-tight">98%</span>
          <span class="block text-xs text-ink-muted mt-1">Client Retention</span>
        </div>
      </div>

      <!-- Tagline -->
      <p
        data-hero-reveal
        style="--delay: 900ms"
        class="max-w-sm text-sm text-ink-secondary leading-relaxed md:text-right"
      >
        Premium websites for local businesses.
        <br class="hidden md:block" />
        Turning visitors into customers, clicks into growth.
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    data-hero-reveal
    style="--delay: 1200ms"
    class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10"
  >
    <span class="text-[10px] text-ink-muted tracking-[0.25em] uppercase font-mono"
      >Scroll</span
    >
    <div class="w-px h-8 bg-rule-light relative overflow-hidden">
      <div class="absolute inset-0 bg-accent animate-scroll-line"></div>
    </div>
  </div>

  <!-- Top-right accent mark — follows mouse -->
  <div
    data-hero-reveal
    data-mouse-parallax="0.8"
    style="--delay: 1000ms; will-change: transform;"
    class="absolute top-28 right-6 md:right-16 lg:right-24 hidden md:block z-10"
  >
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="text-accent opacity-40">
      <path d="M24 0v48M0 24h48" stroke="currentColor" stroke-width="0.5" />
      <circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="0.5" />
    </svg>
  </div>
</section>

<style>
  @keyframes scroll-line {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }
  .animate-scroll-line {
    animation: scroll-line 1.5s cubic-bezier(0.55, 0, 0.1, 1) infinite;
  }
</style>

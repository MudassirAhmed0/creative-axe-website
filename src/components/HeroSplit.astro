---
interface Props {
  headline: string;
  subheadline: string;
  body?: string;
  ctaLabel: string;
  ctaHref: string;
  imageSrc: string;
  imageAlt: string;
}

const { headline, subheadline, body, ctaLabel, ctaHref, imageSrc, imageAlt } = Astro.props;
---

<header class="bg-background py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-16">
      <div class="flex-1">
        <h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          {headline}
        </h1>
        <p class="mt-6 text-lg text-muted">{subheadline}</p>
        {body && <p class="mt-4 text-base leading-relaxed text-muted/80">{body}</p>}
        <div class="mt-10">
          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-8 py-4 text-base font-semibold text-background transition-colors hover:bg-accent-light focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            {ctaLabel}
          </a>
        </div>
      </div>
      <div class="relative flex-1">
        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-border">
          <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" loading="eager" width="800" height="600" />
        </div>
      </div>
    </div>
  </div>
</header>

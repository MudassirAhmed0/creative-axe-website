---
const industries = [
  { name: "Restaurants", slug: "restaurants", description: "Menus, online ordering, reservations — the full plate.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2M7 2v20M21 15V2l-5 5 5 5M21 15v7" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "Plumbing & HVAC", slug: "plumbers", description: "Emergency calls, service areas, trust signals.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M4 22h16M4 22V8l4-4h8l4 4v14M9 22v-6h6v6M12 2v4" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "Dental & Medical", slug: "dentists", description: "Patient forms, appointment scheduling, insurance info.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 2L8 6C6.5 7.5 6 9.5 6 11c0 3.3 2.7 6 6 6s6-2.7 6-6c0-1.5-.5-3.5-2-5l-4-4zM12 17v5M9 22h6" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "Contractors", slug: "contractors", description: "Project galleries, quotes, and location maps.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "Lawyers", slug: "lawyers", description: "Practice areas, attorney profiles, case results.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 22V8M5 12l7-10 7 10M3 20h18" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "HVAC", slug: "hvac", description: "Emergency CTAs, service areas, seasonal campaigns.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M6.5 6.5L17.5 17.5M6.5 17.5L17.5 6.5M12 2v20M2 12h20" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "Landscaping", slug: "plumbers", description: "Project galleries, service areas, seasonal offers.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 22V8M5 12l7-10 7 10M3 20h18" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
  { name: "Cleaning Services", slug: "contractors", description: "Instant quotes, booking, before/after showcases.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 2L8 8h8l-4-6zM8 8l-4 14h16L16 8H8z" stroke-linecap="round" stroke-linejoin="round" /></svg>` },
];
---

<section class="py-28 md:py-36 relative border-t border-border" aria-labelledby="industries-heading">
  <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-accent/[0.02] blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <span class="text-xs font-mono text-accent tracking-widest uppercase">Industries</span>
        <h2 id="industries-heading" class="mt-4 text-4xl md:text-5xl font-bold tracking-tight">
          Built for <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">your industry</span>
        </h2>
        <p class="mt-4 text-muted max-w-lg">
          We know your business because we've built hundreds of sites just like yours. Every template, every feature — tailored to what your customers actually need.
        </p>
      </div>
      <a href="/services" class="text-sm text-accent hover:text-accent-light transition-colors font-medium shrink-0">
        View all services &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {industries.map((industry) => (
        <a
          href={`/for/${industry.slug}`}
          class="group bg-card border border-border rounded-2xl p-6 hover:border-accent/30 hover:bg-card-hover transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-4 group-hover:bg-accent/20 transition-colors" aria-hidden="true">
            <Fragment set:html={industry.icon} />
          </div>
          <h3 class="font-semibold mb-1.5">{industry.name}</h3>
          <p class="text-sm text-muted leading-relaxed">{industry.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

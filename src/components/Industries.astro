---
const industries = [
  { name: "Restaurants", slug: "restaurants", num: "01" },
  { name: "Dental Practices", slug: "dentists", num: "02" },
  { name: "Contractors", slug: "contractors", num: "03" },
  { name: "Law Firms", slug: "lawyers", num: "04" },
  { name: "HVAC Companies", slug: "hvac", num: "05" },
  { name: "Plumbers", slug: "plumbers", num: "06" },
];
---

<section
  id="industries"
  class="section-over-hero bg-surface-alt py-28 md:py-44 px-6 md:px-16 lg:px-24 relative grain"
  data-theme="dark"
>
  <div class="relative z-10">
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 mb-16 md:mb-20">
      <div class="lg:w-1/3">
        <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
          Industries
        </p>
      </div>
      <div class="lg:w-2/3">
        <h2
          data-reveal
          style="--delay: 100ms"
          class="text-3xl md:text-5xl font-bold leading-[0.95] tracking-tight"
        >
          Built for businesses<br class="hidden md:block" />
          like <span class="text-accent">yours</span>
        </h2>
      </div>
    </div>

    <div class="lg:ml-auto lg:w-2/3 lg:pl-0">
      {
        industries.map((ind, i) => (
          <a
            href={`/for/${ind.slug}`}
            class="block border-t border-rule-light group"
            data-reveal
            style={`--delay: ${i * 70}ms`}
          >
            <div class="flex items-center justify-between py-6 md:py-8">
              <div class="flex items-center gap-6 md:gap-10">
                <span class="text-xs font-mono text-ink-muted group-hover:text-accent transition-colors duration-300">
                  {ind.num}
                </span>
                <span class="text-xl md:text-3xl lg:text-4xl font-bold tracking-tight group-hover:text-accent transition-colors duration-300">
                  {ind.name}
                </span>
              </div>
              <span class="w-10 h-10 rounded-full border border-rule-light flex items-center justify-center group-hover:border-accent group-hover:bg-accent group-hover:text-surface transition-all duration-300">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path
                    d="M4 4h6v6M10 4L4 10"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
      <div class="border-t border-rule-light" data-reveal-line style="--delay: 420ms"></div>
    </div>
  </div>
</section>

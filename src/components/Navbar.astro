---
import NavbarToggle from "./NavbarToggle";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center font-bold text-background text-sm group-hover:scale-110 transition-transform">
        CA
      </div>
      <span class="font-bold text-lg tracking-tight">
        Creative<span class="text-accent">Axe</span>
      </span>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-8">
      <a href="/services" class="text-sm text-muted hover:text-foreground transition-colors">Services</a>
      <a href="/work" class="text-sm text-muted hover:text-foreground transition-colors">Our Work</a>
      <a href="/for/restaurants" class="text-sm text-muted hover:text-foreground transition-colors">Industries</a>
      <a href="/services" class="text-sm bg-accent hover:bg-accent-light text-background font-semibold px-5 py-2 rounded-lg transition-colors">
        Get Your Free Site
      </a>
    </div>

    <!-- Mobile toggle (React island — zero JS on desktop) -->
    <NavbarToggle client:media="(max-width: 767px)" />
  </div>
</nav>

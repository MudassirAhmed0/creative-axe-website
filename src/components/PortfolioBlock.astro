---
interface Project {
  title: string;
  description?: string;
  imageSrc: string;
  imageAlt: string;
  tags?: string[];
}

interface Props {
  headline: string;
  subheadline?: string;
  projects: Project[];
  columns?: 2 | 3;
}

const { headline, subheadline, projects, columns = 3 } = Astro.props;

const colClass: Record<number, string> = {
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-2 lg:grid-cols-3",
};
---

<section class="bg-background py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-14 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{headline}</h2>
      {subheadline && <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">{subheadline}</p>}
    </div>

    <ul class={`grid grid-cols-1 gap-6 ${colClass[columns]}`} aria-label="Portfolio projects">
      {projects.map((project) => (
        <li class="group relative overflow-hidden rounded-2xl">
          <div class="aspect-[4/3] overflow-hidden bg-card">
            <img
              src={project.imageSrc}
              alt={project.imageAlt}
              width="800"
              height="600"
              class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/85 via-black/30 to-transparent p-6 opacity-0 transition-opacity duration-400 group-hover:opacity-100 focus-within:opacity-100" aria-hidden="true">
            {project.tags && project.tags.length > 0 && (
              <ul class="mb-3 flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <li class="rounded-full border border-accent/50 bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent backdrop-blur-sm">
                    {tag}
                  </li>
                ))}
              </ul>
            )}
            <h3 class="text-lg font-bold leading-snug text-white">{project.title}</h3>
            {project.description && (
              <p class="mt-1.5 text-sm leading-relaxed text-white/75">{project.description}</p>
            )}
          </div>

          <div class="border-t border-border bg-card px-5 py-4 transition-colors duration-300 group-hover:bg-card/50">
            <p class="truncate text-sm font-semibold">{project.title}</p>
            {project.tags && project.tags.length > 0 && (
              <ul class="mt-1.5 flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <li class="text-xs font-medium text-muted">#{tag}</li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

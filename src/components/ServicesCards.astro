---
interface Service {
  name: string;
  description: string;
  icon: string;
}

interface Props {
  headline: string;
  subheadline?: string;
  services: Service[];
}

const { headline, subheadline, services } = Astro.props;
---

<section class="bg-background py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-14 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{headline}</h2>
      {subheadline && <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">{subheadline}</p>}
    </div>

    <ul class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3" aria-label="Services">
      {services.map((service) => (
        <li class="group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:shadow-[0_0_40px_rgba(249,115,22,0.08)]">
          <div class="flex flex-1 flex-col gap-3 p-8">
            <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-2xl text-accent" aria-hidden="true">
              {service.icon}
            </div>
            <h3 class="text-xl font-bold">{service.name}</h3>
            <p class="flex-1 text-sm leading-relaxed text-muted">{service.description}</p>
            <div class="mt-4 flex items-center gap-2 text-sm font-semibold text-accent" aria-hidden="true">
              <span>Learn more</span>
              <svg class="h-4 w-4 translate-x-0 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-gradient-to-r from-accent to-accent/0 transition-all duration-500 group-hover:w-full" aria-hidden="true"></div>
        </li>
      ))}
    </ul>
  </div>
</section>

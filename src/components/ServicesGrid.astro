---
interface Service {
  name: string;
  description: string;
  icon: string;
}

interface Props {
  headline: string;
  subheadline?: string;
  services: Service[];
  columns?: 2 | 3 | 4;
}

const { headline, subheadline, services, columns = 3 } = Astro.props;

const colClass: Record<number, string> = {
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-2 lg:grid-cols-3",
  4: "sm:grid-cols-2 lg:grid-cols-4",
};
---

<section class="bg-background py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-14 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{headline}</h2>
      {subheadline && <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">{subheadline}</p>}
    </div>

    <ul class={`grid grid-cols-1 gap-6 ${colClass[columns]}`} aria-label="Services">
      {services.map((service) => (
        <li class="group flex flex-col gap-4 rounded-2xl border border-border bg-card p-8 transition-colors duration-300 hover:border-accent/40 hover:bg-card/80">
          {service.icon && (
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-2xl text-accent transition-colors group-hover:bg-accent/20" aria-hidden="true">
              {service.icon}
            </div>
          )}
          <div class="flex flex-col gap-2">
            <h3 class="text-lg font-semibold leading-snug">{service.name}</h3>
            <p class="text-sm leading-relaxed text-muted">{service.description}</p>
          </div>
          <div class="mt-auto h-px w-0 bg-accent transition-all duration-500 group-hover:w-full" aria-hidden="true"></div>
        </li>
      ))}
    </ul>
  </div>
</section>

---
import { AnimatedCounter } from "./AnimatedCounter";

interface Stat {
  value: number;
  suffix?: string;
  prefix?: string;
  label: string;
}

interface Props {
  headline?: string;
  stats: Stat[];
}

const { headline, stats } = Astro.props;

const gridClass = stats.length <= 2
  ? "sm:grid-cols-2"
  : stats.length === 3
    ? "sm:grid-cols-3"
    : "sm:grid-cols-2 lg:grid-cols-4";
---

<section class="bg-background py-20 lg:py-28">
  <div class="mx-auto w-full max-w-7xl px-6">
    {headline && (
      <div class="mb-14 text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{headline}</h2>
      </div>
    )}

    <ul class={`grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-border ${gridClass}`} aria-label="Key statistics">
      {stats.map((stat) => (
        <li class="flex flex-col items-center gap-3 bg-card px-8 py-12 text-center">
          <div class="mb-2 h-1 w-8 rounded-full bg-accent" aria-hidden="true"></div>
          <span class="text-5xl font-extrabold leading-none tracking-tight sm:text-6xl">
            <AnimatedCounter
              client:visible
              target={stat.value}
              prefix={stat.prefix || ""}
              suffix={stat.suffix || ""}
              duration={2200}
            />
          </span>
          <span class="text-sm font-medium uppercase tracking-widest text-muted sm:text-base">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

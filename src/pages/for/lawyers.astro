---
import Base from "../../layouts/Base.astro";
import FinalCTA from "../../components/FinalCTA.astro";
import { AnimatedCounter } from "../../components/AnimatedCounter.tsx";
import { NICHE_DATA } from "../../data/niches";

const data = NICHE_DATA.lawyers;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Creative Axe",
  description: data.metaDescription,
  url: "https://creativeaxe.co/for/lawyers",
  areaServed: "United States",
  knowsAbout: data.title,
};
---

<Base
  title={`${data.title} — Creative Axe`}
  description={data.metaDescription}
  jsonLd={jsonLd}
>
  <section
    data-theme="dark"
    class="bg-surface px-6 md:px-16 lg:px-24 pt-32 md:pt-44 pb-24 md:pb-32"
  >
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-24">
      <div class="lg:w-1/3">
        <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
          Industry
        </p>
      </div>
      <div class="lg:w-2/3">
        <h1
          data-reveal
          style="--delay: 100ms"
          class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-[0.95] tracking-tight mb-8"
        >
          {data.headline}
        </h1>
        <p
          data-reveal
          style="--delay: 200ms"
          class="text-lg text-ink-secondary max-w-xl leading-relaxed mb-6"
        >
          {data.subheadline}
        </p>
        <p
          data-reveal
          style="--delay: 300ms"
          class="text-base text-ink-secondary max-w-lg leading-relaxed"
        >
          {data.body}
        </p>
      </div>
    </div>
  </section>

  <section data-theme="dark" class="bg-surface-alt py-28 md:py-44 px-6 md:px-16 lg:px-24 relative grain">
    <div class="relative z-10 flex flex-col lg:flex-row gap-16 lg:gap-24">
      <div class="lg:w-1/3">
        <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
          What We Build
        </p>
      </div>
      <div class="lg:w-2/3">
        {
          data.services.map((service, i) => (
            <div
              class="border-t border-rule-light py-8"
              data-reveal
              style={`--delay: ${i * 100}ms`}
            >
              <h3 class="text-xl md:text-2xl font-bold tracking-tight mb-3">
                {service.name}
              </h3>
              <p class="text-ink-secondary text-base leading-relaxed max-w-xl">
                {service.description}
              </p>
            </div>
          ))
        }
        <div class="border-t border-rule-light"></div>
      </div>
    </div>
  </section>

  <section data-theme="dark" class="bg-surface py-28 md:py-44 px-6 md:px-16 lg:px-24">
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
      <div class="lg:w-1/3">
        <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
          Results
        </p>
      </div>
      <div class="lg:w-2/3">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {
            data.stats.map((stat, i) => (
              <div data-reveal style={`--delay: ${i * 100}ms`} class="border-t border-rule-light pt-6">
                <span class="text-4xl md:text-5xl font-bold tracking-tight block mb-2">
                  <AnimatedCounter
                    client:visible
                    target={stat.value}
                    suffix={stat.suffix}
                    prefix={stat.prefix}
                  />
                </span>
                <span class="text-xs text-ink-muted">{stat.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <FinalCTA
    headline={data.ctaHeadline}
    description="Find out exactly where your current website is losing you customers. Free, no strings attached."
  />
</Base>

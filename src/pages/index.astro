---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Capabilities from "../components/Capabilities.astro";
import CompanySection from "../components/CompanySection.astro";
import Industries from "../components/Industries.astro";
import FinalCTA from "../components/FinalCTA.astro";

const projects = [
  {
    name: "Bella Cucina",
    type: "Restaurant Website",
    result: "+40% bookings",
  },
  {
    name: "Smith & Associates",
    type: "Law Firm Website",
    result: "+200% consultations",
  },
  {
    name: "Bright Smile Dental",
    type: "Dental Practice",
    result: "+180% new patients",
  },
  {
    name: "ProBuild Construction",
    type: "Contractor Website",
    result: "+150% quote requests",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Creative Axe",
  url: "https://creativeaxe.co",
  description:
    "We design and build exceptional websites for local businesses.",
  areaServed: "United States",
};
---

<Base
  title="Creative Axe — We Build Websites That Convert"
  description="We design and build exceptional websites for local businesses — turning visitors into customers, and clicks into growth."
  jsonLd={jsonLd}
>
  <Hero />

  <!-- Selected Work — slides over the sticky hero -->
  <section
    class="section-over-hero bg-surface py-28 md:py-44 px-6 md:px-16 lg:px-24 relative"
    data-theme="dark"
  >
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 mb-16 md:mb-24">
      <div class="lg:w-1/3">
        <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
          Selected Work
        </p>
      </div>
      <div class="lg:w-2/3">
        <p
          data-reveal
          style="--delay: 100ms"
          class="text-xl md:text-2xl text-ink-secondary leading-relaxed max-w-xl"
        >
          Websites designed to perform — built for businesses that want
          real results, not just a pretty homepage.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {
        projects.map((project, i) => (
          <a
            href="/work"
            class="group block card-hover"
            data-reveal
            style={`--delay: ${150 + i * 120}ms`}
          >
            <div class="relative aspect-[4/3] rounded-lg overflow-hidden bg-surface-elevated border border-rule mb-5 glow-accent-hover">
              <div class="card-image absolute inset-0 flex items-center justify-center">
                <span class="text-ink-faint text-[clamp(1.5rem,4vw,3rem)] font-bold tracking-tight select-none group-hover:text-ink-muted transition-colors duration-500">
                  {project.name}
                </span>
              </div>
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              <!-- Arrow -->
              <div class="absolute bottom-4 right-4 w-8 h-8 rounded-full border border-rule-light flex items-center justify-center opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 group-hover:border-accent group-hover:bg-accent transition-all duration-300">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path
                    d="M3 3h6v6M9 3L3 9"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-ink group-hover:text-surface"
                  />
                </svg>
              </div>
              <!-- Result badge -->
              <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span class="text-xs font-mono text-accent bg-surface/80 backdrop-blur-sm rounded-full px-3 py-1">
                  {project.result}
                </span>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-ink group-hover:text-accent transition-colors duration-300">
                  {project.name}
                </p>
                <p class="text-xs text-ink-muted mt-0.5">{project.type}</p>
              </div>
              <span class="text-xs font-mono text-accent opacity-60 group-hover:opacity-100 transition-opacity duration-300">
                {project.result}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <Capabilities />
  <CompanySection />
  <Industries />
  <FinalCTA />
</Base>
